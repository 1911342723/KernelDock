# ============================================================================
# 代码执行沙箱服务环境变量配置示例
# ============================================================================
# 
# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据服务器配置修改参数
# 3. docker-compose 会自动加载 .env 文件
#
# 当前配置针对 4C8G 服务器优化
# 如果是 8C16G 服务器，可以翻倍相关参数
# ============================================================================

# ============================================================================
# 基础配置
# ============================================================================
PYTHONUNBUFFERED=1
WORKSPACE_DIR=/workspace
SANDBOX_DOCKER_IMAGE=code-executor-sandbox:latest

# ============================================================================
# 资源限制配置（针对4C8G服务器优化）
# ============================================================================
# 每个沙箱的默认资源限制
SANDBOX_RESOURCE__DEFAULT_CPU=1.0              # 每个沙箱默认 1核
SANDBOX_RESOURCE__DEFAULT_MEMORY_MB=256        # 每个沙箱默认 256MB（提高并发）
SANDBOX_RESOURCE__DEFAULT_DISK_MB=1024         # 每个沙箱默认 1GB 磁盘
SANDBOX_RESOURCE__DEFAULT_PIDS=100             # 每个沙箱默认 100 个进程

# 资源上限（防止单个沙箱占用过多资源）
SANDBOX_RESOURCE__MAX_CPU=2.0                  # 最大允许 2核
SANDBOX_RESOURCE__MAX_MEMORY_MB=2048           # 最大允许 2GB
SANDBOX_RESOURCE__MAX_DISK_MB=10240            # 最大允许 10GB

# ============================================================================
# 并发控制配置（令牌桶算法）
# ============================================================================
# 关键参数：限制真实并发执行数 = CPU核心数，避免上下文切换
SANDBOX_QUEUE__MAX_CONCURRENT_EXECUTIONS=4     # 最多并发 4 个任务（=4核）
SANDBOX_QUEUE__INITIAL_AVG_EXECUTION_TIME=5.0  # 初始平均执行时间估算（秒）
SANDBOX_QUEUE__QUEUE_TIMEOUT=300               # 排队超时 5分钟

# 8C16G 服务器推荐配置：
# SANDBOX_QUEUE__MAX_CONCURRENT_EXECUTIONS=8

# ============================================================================
# 容器池配置（预热容器池）
# ============================================================================
# 预热容器池：维护一定数量的待命容器，快速分配（<1秒）
SANDBOX_POOL__POOL_SIZE=6                      # 预热容器数量（6 * 256MB = 1.5GB）
SANDBOX_POOL__MAX_CONCURRENT_SANDBOXES=20      # 最大并发沙箱数（20 * 256MB = 5GB）
SANDBOX_POOL__CONTAINER_MAX_AGE_SECONDS=3600   # 容器最大存活 1小时（防止资源泄漏）
SANDBOX_POOL__HEALTH_CHECK_INTERVAL=60         # 健康检查间隔 1分钟

# 8C16G 服务器推荐配置：
# SANDBOX_POOL__POOL_SIZE=12
# SANDBOX_POOL__MAX_CONCURRENT_SANDBOXES=40

# ============================================================================
# 超时配置
# ============================================================================
# 优化超时设置，提高资源利用率
SANDBOX_TIMEOUT__EXECUTION_TIMEOUT=300         # 代码执行超时 5分钟
SANDBOX_TIMEOUT__SESSION_IDLE_TIMEOUT=600      # 会话空闲超时 10分钟（降低以提高并发）
SANDBOX_TIMEOUT__SESSION_MAX_TIMEOUT=43200     # 会话最大时长 12小时
SANDBOX_TIMEOUT__SANDBOX_STARTUP_TIMEOUT=30    # 沙箱启动超时 30秒

# 如果需要更长的会话时间（如长时间交互式分析）：
# SANDBOX_TIMEOUT__SESSION_IDLE_TIMEOUT=1800   # 30分钟
# SANDBOX_TIMEOUT__SESSION_MAX_TIMEOUT=86400   # 24小时

# ============================================================================
# Fire-and-Forget 配置（无状态短链接模式）
# ============================================================================
# 即用即毁执行模式：借容器 → 注入数据 → 执行 → 清理 → 归还
SANDBOX_FIRE_AND_FORGET__DEFAULT_TIMEOUT=30    # 默认执行超时 30秒
SANDBOX_FIRE_AND_FORGET__MAX_DATA_SIZE_MB=50   # 数据文件总大小上限 50MB
SANDBOX_FIRE_AND_FORGET__CLEANUP_TIMEOUT=10    # 容器清理超时 10秒

# ============================================================================
# 网络配置
# ============================================================================
# 默认禁用出站网络（数据分析场景推荐）
SANDBOX_NETWORK__DEFAULT_ALLOW_OUTBOUND=false
# 如果需要访问外部API，可以配置白名单：
# SANDBOX_NETWORK__ALLOWED_HOSTS=api.example.com,data.example.com

# ============================================================================
# 安全配置
# ============================================================================
# gVisor 用户态内核隔离（需要 Docker 配置 runsc runtime）
SANDBOX_SECURITY__USE_GVISOR=false             # 是否使用 gVisor
SANDBOX_SECURITY__GVISOR_RUNTIME=runsc         # gVisor 运行时名称

# 安全加固选项
SANDBOX_SECURITY__READ_ONLY_ROOTFS=true        # 只读根文件系统
SANDBOX_SECURITY__DISABLE_NETWORK=true         # 禁用网络
SANDBOX_SECURITY__DROP_ALL_CAPABILITIES=true   # 移除所有 Linux capabilities
SANDBOX_SECURITY__NO_NEW_PRIVILEGES=true       # 禁止提权

# ============================================================================
# Docker 配置
# ============================================================================
SANDBOX_DOCKER_SOCKET=unix:///var/run/docker.sock
SANDBOX_NETWORK_NAME=sandbox_network
SANDBOX_WORKSPACE_BASE=/var/sandbox/workspaces

# ============================================================================
# 日志配置
# ============================================================================
SANDBOX_LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Sentry 监控配置（可选）
# ============================================================================
# SANDBOX_SENTRY_DSN=https://your-sentry-dsn
# SANDBOX_SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================================================
# 性能调优建议
# ============================================================================
#
# 1. 4C8G 服务器（当前配置）：
#    - 并发执行：4个
#    - 预热容器：6个
#    - 最大沙箱：20个
#    - 内存占用：~5GB（20 * 256MB）
#    - 预期QPS：~0.8（假设平均执行5秒）
#
# 2. 8C16G 服务器（推荐升级）：
#    - 并发执行：8个
#    - 预热容器：12个
#    - 最大沙箱：40个
#    - 内存占用：~10GB（40 * 256MB）
#    - 预期QPS：~1.6（假设平均执行5秒）
#
# 3. 监控指标：
#    - 容器池可用数：应保持 > 0
#    - 执行队列长度：应 < 10
#    - 平均等待时间：应 < 5秒
#    - CPU 使用率：应 < 80%
#
# 4. 优化方向：
#    - 如果 CPU 使用率低：增加 MAX_CONCURRENT_EXECUTIONS
#    - 如果内存充足：增加 POOL_SIZE 和 MAX_CONCURRENT_SANDBOXES
#    - 如果排队严重：增加 QUEUE_TIMEOUT 或升级服务器
#    - 如果容器池经常为空：增加 POOL_SIZE
#
# ============================================================================


SANDBOX_ALLOW_LOCAL_FALLBACK=false