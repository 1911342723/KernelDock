# =============================================================================
# AgentRun 沙箱自定义镜像 Dockerfile
# 基于 code-executor-service/Dockerfile.sandbox 构建，补充 AgentRun 依赖
# =============================================================================

# ============================================
# 构建阶段：安装 Python 依赖
# ============================================
FROM python:3.11-slim AS builder

# 设置构建阶段环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /build

# 创建 requirements 文件，包含数据分析和科研绘图常用库
# 以及新增的 AgentRun SDK
RUN cat > requirements.txt << 'EOF'
# ===========================================
# 数据处理核心库
# ===========================================
pandas>=2.0.0,<3.0.0
numpy>=1.24.0,<2.0.0
polars>=0.20.0,<1.0.0

# ===========================================
# 科研绘图核心库
# ===========================================
matplotlib>=3.7.0,<4.0.0
seaborn>=0.12.0,<1.0.0
plotly>=5.14.0,<6.0.0
bokeh>=3.3.0,<4.0.0
altair>=5.2.0,<6.0.0
pyecharts>=2.0.0,<3.0.0

# ===========================================
# 科研专用绘图
# ===========================================
wqchartpy>=0.1.10
python-ternary>=1.0.8,<2.0.0
plotnine>=0.12.0,<1.0.0
matplotlib-venn>=0.11.0,<1.0.0
holoviews>=1.18.0,<2.0.0
wordcloud>=1.9.0,<2.0.0
squarify>=0.4.3,<1.0.0
pygal>=3.0.0,<4.0.0
palettable>=3.3.0,<4.0.0
cmocean>=3.0.0,<4.0.0
colorcet>=3.0.0,<4.0.0
SciencePlots>=2.1.0,<3.0.0

# ===========================================
# 科学计算与统计分析
# ===========================================
scipy>=1.10.0,<2.0.0
sympy>=1.12,<2.0.0
statsmodels>=0.14.0,<1.0.0
pingouin>=0.5.3,<1.0.0
scikit-learn>=1.2.0,<2.0.0

# ===========================================
# 地理空间与地图
# ===========================================
geopandas>=0.14.0,<1.0.0
folium>=0.15.0,<1.0.0
shapely>=2.0.0,<3.0.0
cartopy>=0.22.0,<1.0.0
contextily>=1.4.0,<2.0.0

# ===========================================
# 图像处理与文件处理
# ===========================================
pillow>=10.0.0,<12.0.0
opencv-python-headless>=4.8.0,<5.0.0
scikit-image>=0.22.0,<1.0.0
cairosvg>=2.7.0,<3.0.0
openpyxl>=3.1.0,<4.0.0
xlrd>=2.0.0,<3.0.0
xlsxwriter>=3.1.0,<4.0.0
pyarrow>=14.0.0,<16.0.0
python-docx>=1.1.0,<2.0.0
PyPDF2>=3.0.0,<4.0.0

# ===========================================
# 其他杂项
# ===========================================
tabulate>=0.9.0,<1.0.0
tqdm>=4.66.0,<5.0.0
python-dateutil>=2.8.0,<3.0.0
pytz>=2023.3
pyyaml>=6.0.0,<7.0.0
adjustText>=0.8,<1.0.0

# ===========================================
# 阿里云 AgentRun SDK
# ===========================================
agentrun-sdk
EOF

# 安装 Python 依赖到临时目录
RUN pip install --no-cache-dir --target=/build/deps -r requirements.txt

# ============================================
# 最终镜像阶段
# ============================================
FROM python:3.11-slim

LABEL maintainer="AgentRun Custom Image" \
      description="包含科研作图与字体支持的阿里云 AgentRun 沙箱镜像" \
      version="1.0.0"

# 设置环境变量
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONIOENCODING=utf-8 \
    PYTHONUTF8=1 \
    MPLBACKEND=Agg \
    QT_QPA_PLATFORM=offscreen \
    MPLCONFIGDIR=/tmp/matplotlib \
    PYTHONPATH=/opt/sandbox/deps \
    WORKSPACE_DIR=/workspace \
    DATA_DIR=/workspace \
    OUTPUT_DIR=/workspace \
    HOME=/workspace

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    fonts-noto-cjk \
    fonts-noto-cjk-extra \
    fonts-wqy-microhei \
    fonts-wqy-zenhei \
    fontconfig \
    libfreetype6 \
    libpng16-16 \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgdal-dev \
    libgeos-dev \
    libproj-dev \
    graphviz \
    libgraphviz-dev \
    libcairo2 \
    libcairo2-dev \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    gcc \
    g++ \
    wget \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && rm -rf /var/cache/apt/archives/* \
    && rm -rf /tmp/* /var/tmp/* \
    && mkdir -p /usr/share/fonts/truetype/simhei \
    && wget -q -O /usr/share/fonts/truetype/simhei/SimHei.ttf \
       "https://github.com/StellarCN/scp_zh/raw/master/fonts/SimHei.ttf" \
    && fc-cache -fv

# 创建非 root 用户 (AgentRun 沙箱会作为无特权用户运行)
ARG USER_UID=1000
ARG USER_GID=1000

RUN groupadd --gid ${USER_GID} sandbox \
    && useradd --uid ${USER_UID} --gid ${USER_GID} \
       --shell /bin/bash \
       --no-create-home \
       sandbox

# 复制依赖
RUN mkdir -p /opt/sandbox/deps
COPY --from=builder /build/deps /opt/sandbox/deps

# 从原基础镜像拷贝 sandbox_runtime
COPY sandbox_runtime /opt/sandbox/deps/sandbox_runtime

# 创建可写目录
RUN mkdir -p /workspace /tmp/matplotlib \
    && chown -R sandbox:sandbox /workspace /tmp \
    && chmod 755 /workspace \
    && chmod 1777 /tmp \
    && chmod -R 555 /opt/sandbox/deps

USER sandbox
WORKDIR /workspace

# AgentRun code interpreter 沙箱默认入口执行即可，或保留 tail 夯住以方便调试调试
CMD ["tail", "-f", "/dev/null"]
